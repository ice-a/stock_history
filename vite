import { defineConfig } from "vite";
import vue from "@vitejs/plugin-vue";

export default defineConfig(() => {
  // 直接从 process.env 读取 VITE_ 前缀的环境变量
  // Vite 在启动时会自动加载 .env 文件到 process.env
  const llmBaseUrl = (process.env.VITE_LLM_BASE_URL || "").trim().replace(/\/+$/, "");

  if (!llmBaseUrl) {
    return { plugins: [vue()] };
  }

  // 解析 URL，分离域名和路径
  // .env: VITE_LLM_BASE_URL=https://api.longcat.chat/openai/v1
  // targetOrigin = https://api.longcat.chat
  // basePath = /openai/v1
  const targetUrl = new URL(llmBaseUrl);
  const targetOrigin = `${targetUrl.protocol}//${targetUrl.host}`;
  const basePath = targetUrl.pathname;

  return {
    plugins: [vue()],
    server: {
      proxy: {
        // 浏览器请求 /llm/chat/completions
        // 代理 rewrite: /llm → /openai/v1
        // 最终转发到: https://api.longcat.chat/openai/v1/chat/completions
        "/llm": {
          target: targetOrigin,
          changeOrigin: true,
          secure: true,
          rewrite: (path) => {
            const withoutPrefix = path.replace(/^\/llm/, "");
            return basePath + withoutPrefix;
          }
        }
      }
    }
  };
});